<%# Admin: SharePoint MS Graph Credentials %>
<% html_title t(:label_administration), t("sharepoint.admin.title") %>

<%=
  render Primer::OpenProject::PageHeader.new do |header|
    header.with_title { t("sharepoint.admin.title") }
    header.with_breadcrumbs(
      [{ href: admin_index_path, text: t("label_administration") },
       t("sharepoint.admin.title")]
    )
  end
%>

<%# ─── Setup Guide ───────────────────────────────────────────────────────── %>
<div class="op-toast -info" style="align-items:flex-start; margin-bottom:2rem;">
  <span class="op-toast--content" style="width:100%">
    <strong style="display:block; margin-bottom:0.25rem; font-size:1rem;">
      <%= t("sharepoint.admin.guide.title") %>
    </strong>
    <p style="margin:0 0 0.75rem; font-size:0.9rem;">
      <%= t("sharepoint.admin.guide.subtitle") %>
    </p>
    <ol style="margin:0; padding-left:1.5rem;">
      <% [
        { title: t("sharepoint.admin.guide.step1_title"), body: t("sharepoint.admin.guide.step1_body") },
        { title: t("sharepoint.admin.guide.step2_title"), body: t("sharepoint.admin.guide.step2_body") },
        { title: t("sharepoint.admin.guide.step3_title"), body: t("sharepoint.admin.guide.step3_body") },
        { title: t("sharepoint.admin.guide.step4_title"), body: t("sharepoint.admin.guide.step4_body") },
        { title: t("sharepoint.admin.guide.step5_title"), body: t("sharepoint.admin.guide.step5_body") },
        { title: t("sharepoint.admin.guide.step6_title"), body: t("sharepoint.admin.guide.step6_body") }
      ].each do |step| %>
        <li style="margin-bottom:0.5rem; line-height:1.5;">
          <strong><%= step[:title] %></strong><br>
          <span style="font-size:0.875rem;"><%= step[:body] %></span>
        </li>
      <% end %>
    </ol>
  </span>
</div>

<%# ─── Credentials Form ──────────────────────────────────────────────────── %>
<%= styled_form_tag(admin_sharepoint_credentials_path, method: :patch) do %>
  <section class="form--section">
    <div class="form--field">
      <label class="form--label"><%= t("sharepoint.admin.tenant_id") %></label>
      <div class="form--field-container">
        <%= text_field_tag :sharepoint_tenant_id,
              Setting.sharepoint_tenant_id,
              class: "form--text-field",
              placeholder: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" %>
      </div>
    </div>

    <div class="form--field">
      <label class="form--label"><%= t("sharepoint.admin.client_id") %></label>
      <div class="form--field-container">
        <%= text_field_tag :sharepoint_client_id,
              Setting.sharepoint_client_id,
              class: "form--text-field",
              placeholder: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" %>
      </div>
    </div>

    <div class="form--field">
      <label class="form--label"><%= t("sharepoint.admin.client_secret") %></label>
      <div class="form--field-container">
        <%= password_field_tag :sharepoint_client_secret,
              Setting.sharepoint_client_secret,
              class: "form--text-field" %>
      </div>
    </div>

    <div class="form--field">
      <label class="form--label"><%= t("sharepoint.admin.root_url") %></label>
      <div class="form--field-container">
        <%= text_field_tag :sharepoint_root_url,
              Setting.sharepoint_root_url,
              class: "form--text-field",
              placeholder: "https://contoso.sharepoint.com" %>
      </div>
    </div>
  </section>

  <div class="generic-table--action-buttons"
       style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;"
       data-controller="sharepoint-test"
       data-sharepoint-test-url-value="<%= test_admin_sharepoint_credentials_path %>"
       data-sharepoint-test-connecting-text-value="<%= t('sharepoint.admin.test_connecting') %>">
    <%= styled_button_tag t(:button_save), class: "-primary -with-icon icon-checkmark" %>
    <%= button_tag t("sharepoint.admin.test_btn"),
          type: "button",
          class: "button",
          "data-sharepoint-test-target": "btn",
          "data-action": "click->sharepoint-test#run" %>
    <span data-sharepoint-test-target="result"
          style="display:none; font-size:0.875rem; font-weight:700;"></span>
  </div>
<% end %>
